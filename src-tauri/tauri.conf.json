{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "filehub-desktop",
  "version": "1.0.2",
  "identifier": "com.exiahuang.filehub",
  "build": {
    "beforeDevCommand": "vite build",
    "beforeBuildCommand": "vite build",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FileHub",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["dist"]
  }
}
